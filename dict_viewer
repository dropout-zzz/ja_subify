class InputBaseWordDialog(QDialog):
  def __init__(self, parent: QWidget):
    QDialog.__init__(self, parent)

    self.resize(250, 0)

    self.__layout = QVBoxLayout(self)
    self.__edit = QLineEdit()
    self.__layout.addWidget(self.__edit)

    self.__result = ''

    self.__edit.returnPressed.connect(self.__do_commit)

  @Slot()
  def __do_commit(self):
    self.__result = self.__edit.text()

    if self.__result == '':
      print('word cannot be empty')
      return

    self.done(QDialog.DialogCode.Accepted)

  def getBaseWordResult(self) -> str:
    assert self.__result != ''
    return self.__result

